[app]
title = "Credit Card Fraud Detection"
favicon = "💳"

[client]
showErrorDetails = true
toolbarMode = "viewer"

[server]
headless = true
port = 8501
address = 0.0.0.0
maxUploadSize = 200
enableXsrfProtection = true
enableCORS = true

[logger]
level = "warning"

[theme]
primaryColor = "#1f77d3"
backgroundColor = "#ffffff"
secondaryBackgroundColor = "#f0f2f6"
textColor = "#262730"
font = "sans serif"
